#!/usr/bin/env python3
"""cost-guard — USD budget enforcement for Claude Code.

Single binary that handles every plugin subcommand:
  halt-check                 — hook dispatcher (reads hook JSON on stdin)
  indicator                  — render cost-guard's bottom-row indicator
                               (wraps a pre-existing bottom-row command if
                               one was present at install time)
  status [--json]            — print current session spend, rate, and caps
  diag                       — dump plugin state (for debugging)
  set-session-limit N        — update max_usd_per_session (USD)
  set-step-limit N           — update max_usd_per_step (USD)
  set-rate N                 — update rate_per_min_usd (USD/min)
  set-subagent-cap N         — update max_subagent_spawns_per_step
  set-warn N                 — update warn_at_usd (USD)
  pause / resume             — temporary disable / enable (session or global)
  install-indicator [mode]   — install cost-guard's bottom-row indicator;
                               mode = compose | replace
  uninstall-indicator        — restore whatever was in the bottom row before

Enforcement runs from hooks reading the session's JSONL transcript; the
indicator is purely cosmetic and halts run identically whether it is
installed or not. Top-level exceptions are swallowed and the process exits
0; a plugin bug must never block Claude Code. Exit code 2 is reserved for
explicit halt decisions.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Tuple


# --- paths ------------------------------------------------------------------

def _plugin_root() -> Path:
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        return Path(env)
    return Path(__file__).resolve().parent.parent


def _plugin_data() -> Path:
    env = os.environ.get("CLAUDE_PLUGIN_DATA")
    if env:
        return Path(env)
    # Fallback: match the path Claude Code uses when loading the plugin via
    # `--plugin-dir`. Claude Code resolves `${CLAUDE_PLUGIN_DATA}` to
    # `~/.claude/plugins/data/<plugin-id>/`, where <plugin-id> for a local-dir
    # load is `<plugin-name>-inline`. Using the same path here keeps hook
    # writes and CLI reads/writes pointed at the same directory even when an
    # env var is missing (e.g., when running the binary from a user shell).
    return Path.home() / ".claude" / "plugins" / "data" / "cost-guard-inline"


PLUGIN_ROOT = _plugin_root()
PLUGIN_DATA = _plugin_data()

PRICING_FILE = PLUGIN_ROOT / "pricing.json"
COST_LEDGER = PLUGIN_DATA / "cost-ledger.jsonl"
OVERRIDES = PLUGIN_DATA / "overrides.json"
SESSIONS_DIR = PLUGIN_DATA / "sessions"
HALT_LOG = PLUGIN_DATA / "halt-log.jsonl"
SEED_MARKER = PLUGIN_DATA / ".seeded"
INDICATOR_STATE = PLUGIN_DATA / "indicator.json"

WINDOW_5H_SECONDS = 5 * 60 * 60
WINDOW_RATE_SECONDS = 5 * 60

DEFAULTS: Dict[str, Any] = {
    "enabled": True,
    "max_usd_per_session": 10.00,
    "max_usd_per_step": 2.00,
    "rate_per_min_usd": 0.50,
    "max_subagent_spawns_per_step": 8,
    "warn_at_usd": 7.00,
    "seed_from_history": True,
    "log_decisions": True,
}


# --- file helpers -----------------------------------------------------------

def _ensure_data_dir() -> None:
    PLUGIN_DATA.mkdir(parents=True, exist_ok=True)
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)


def _iso_to_epoch(s: str) -> float:
    try:
        if s.endswith("Z"):
            s = s[:-1] + "+00:00"
        return datetime.fromisoformat(s).timestamp()
    except Exception:
        return time.time()


def _read_json(path: Path, default: Any = None) -> Any:
    try:
        return json.loads(path.read_text())
    except Exception:
        return default


def _write_json_atomic(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(obj, indent=2))
    os.replace(tmp, path)


def _append_jsonl(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a") as f:
        f.write(json.dumps(obj) + "\n")


def _coerce(value: str, target_type: type) -> Any:
    if target_type is bool:
        return str(value).lower() in ("true", "1", "yes", "on")
    if target_type is int:
        return int(float(value))
    if target_type is float:
        return float(value)
    return value


# --- config -----------------------------------------------------------------

def load_config() -> Dict[str, Any]:
    cfg = dict(DEFAULTS)
    for key, default in DEFAULTS.items():
        raw = os.environ.get(f"CLAUDE_PLUGIN_OPTION_{key.upper()}")
        if raw is not None and raw != "":
            try:
                cfg[key] = _coerce(raw, type(default))
            except Exception:
                pass
    overrides = _read_json(OVERRIDES, {}) or {}
    for key, value in overrides.items():
        if key in DEFAULTS:
            try:
                target = type(DEFAULTS[key])
                cfg[key] = value if isinstance(value, target) else _coerce(str(value), target)
            except Exception:
                cfg[key] = value
    return cfg


def set_override(key: str, value: Any) -> None:
    if key not in DEFAULTS:
        raise ValueError(f"unknown config key: {key}")
    _ensure_data_dir()
    current = _read_json(OVERRIDES, {}) or {}
    current[key] = value
    _write_json_atomic(OVERRIDES, current)


# --- pricing ----------------------------------------------------------------

_PRICING: Optional[Dict[str, Any]] = None


def pricing() -> Dict[str, Any]:
    global _PRICING
    if _PRICING is None:
        _PRICING = _read_json(PRICING_FILE, {}) or {}
    return _PRICING


def model_rates(model_id: str) -> Dict[str, float]:
    p = pricing()
    tiers = p.get("tiers", {}) or {}
    rules = p.get("model_tier_rules", []) or []
    default_tier = p.get("unknown_model_tier", "opus")
    if model_id:
        for rule in rules:
            needle = rule.get("contains", "")
            if needle and needle in model_id:
                return tiers.get(rule.get("tier"), tiers.get(default_tier, {}))
    return tiers.get(default_tier, {})


def entry_cost_usd(usage: Dict[str, Any], model_id: str) -> float:
    r = model_rates(model_id)
    if not r:
        return 0.0
    input_tokens = int(usage.get("input_tokens") or 0)
    output_tokens = int(usage.get("output_tokens") or 0)
    cache_read = int(usage.get("cache_read_input_tokens") or 0)
    cc = usage.get("cache_creation") or {}
    if isinstance(cc, dict) and cc:
        cw5 = int(cc.get("ephemeral_5m_input_tokens") or 0)
        cw1 = int(cc.get("ephemeral_1h_input_tokens") or 0)
    else:
        cw5 = int(usage.get("cache_creation_input_tokens") or 0)
        cw1 = 0
    return (
        input_tokens * r.get("input", 0.0)
        + output_tokens * r.get("output", 0.0)
        + cw5 * r.get("cache_write_5m", 0.0)
        + cw1 * r.get("cache_write_1h", 0.0)
        + cache_read * r.get("cache_read", 0.0)
    ) / 1_000_000.0


# --- transcript parsing -----------------------------------------------------

def parse_transcript(
    path: Path | str, since_ts: Optional[float] = None
) -> Iterable[Tuple[float, str, float]]:
    p = Path(path)
    if not p.exists():
        return
    try:
        with p.open("r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except Exception:
                    continue
                if entry.get("type") != "assistant":
                    continue
                msg = entry.get("message") or {}
                usage = msg.get("usage") or {}
                if not usage:
                    continue
                model = msg.get("model") or entry.get("model") or ""
                ts_str = entry.get("timestamp") or ""
                ts_epoch = _iso_to_epoch(ts_str) if ts_str else time.time()
                if since_ts is not None and ts_epoch < since_ts:
                    continue
                yield ts_epoch, model, entry_cost_usd(usage, model)
    except Exception:
        return


def subagent_transcripts_for(main_transcript: Path | str) -> List[Path]:
    p = Path(main_transcript)
    sub_dir = p.parent / p.stem / "subagents"
    if sub_dir.is_dir():
        return sorted(sub_dir.glob("*.jsonl"))
    return []


# --- ledger -----------------------------------------------------------------

def ledger_append(ts: float, session_id: str, model: str, cost: float, origin: str) -> None:
    _ensure_data_dir()
    _append_jsonl(
        COST_LEDGER,
        {
            "ts": ts,
            "session_id": session_id,
            "model": model,
            "cost_usd": round(cost, 6),
            "origin": origin,
        },
    )


def ledger_since(since_ts: float) -> List[Dict[str, Any]]:
    if not COST_LEDGER.exists():
        return []
    out: List[Dict[str, Any]] = []
    try:
        with COST_LEDGER.open("r") as f:
            for line in f:
                try:
                    rec = json.loads(line)
                except Exception:
                    continue
                if rec.get("ts", 0) >= since_ts:
                    out.append(rec)
    except Exception:
        pass
    return out


def ledger_compact() -> None:
    if not COST_LEDGER.exists():
        return
    cutoff = time.time() - WINDOW_5H_SECONDS
    try:
        rows = ledger_since(cutoff)
        tmp = COST_LEDGER.with_suffix(".jsonl.tmp")
        with tmp.open("w") as f:
            for rec in rows:
                f.write(json.dumps(rec) + "\n")
        os.replace(tmp, COST_LEDGER)
    except Exception:
        pass


# --- session state ----------------------------------------------------------

def session_path(session_id: str) -> Path:
    return SESSIONS_DIR / f"{session_id}.json"


def session_load(session_id: str) -> Dict[str, Any]:
    return _read_json(session_path(session_id), {}) or {}


def session_save(session_id: str, state: Dict[str, Any]) -> None:
    _ensure_data_dir()
    _write_json_atomic(session_path(session_id), state)


def session_update(session_id: str, **changes: Any) -> Dict[str, Any]:
    state = session_load(session_id)
    state.update(changes)
    session_save(session_id, state)
    return state


# --- history seeding (V5) ---------------------------------------------------

def seed_from_history(max_transcripts: int = 200) -> int:
    _ensure_data_dir()
    if SEED_MARKER.exists():
        return 0
    projects = Path.home() / ".claude" / "projects"
    if not projects.is_dir():
        SEED_MARKER.write_text(str(int(time.time())))
        return 0
    cutoff = time.time() - WINDOW_5H_SECONDS
    candidates: List[Path] = []
    try:
        for jsonl in projects.glob("*/*.jsonl"):
            try:
                if jsonl.stat().st_mtime >= cutoff:
                    candidates.append(jsonl)
            except OSError:
                continue
        candidates.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    except Exception:
        candidates = []
    added = 0
    for tp in candidates[:max_transcripts]:
        session_id = tp.stem
        try:
            for ts, model, cost in parse_transcript(tp, since_ts=cutoff):
                if cost <= 0:
                    continue
                ledger_append(ts, session_id, model, cost, origin="seed")
                added += 1
            for sub in subagent_transcripts_for(tp):
                for ts, model, cost in parse_transcript(sub, since_ts=cutoff):
                    if cost <= 0:
                        continue
                    ledger_append(ts, session_id, model, cost, origin="seed-sub")
                    added += 1
        except Exception:
            continue
    SEED_MARKER.write_text(str(int(time.time())))
    return added


# --- aggregates -------------------------------------------------------------

def global_5h_cost_usd() -> float:
    """Aggregate of ALL sessions in the trailing 5h (informational only)."""
    rows = ledger_since(time.time() - WINDOW_5H_SECONDS)
    return sum(float(r.get("cost_usd") or 0.0) for r in rows)


def session_cost_usd(session_id: str) -> float:
    """This session's cost over the trailing 5h."""
    if not session_id:
        return 0.0
    rows = ledger_since(time.time() - WINDOW_5H_SECONDS)
    return sum(
        float(r.get("cost_usd") or 0.0)
        for r in rows
        if r.get("session_id") == session_id
    )


def session_rate_per_min_usd(session_id: str) -> float:
    """This session's trailing 5-minute burn rate (USD/min)."""
    if not session_id:
        return 0.0
    rows = ledger_since(time.time() - WINDOW_RATE_SECONDS)
    total = sum(
        float(r.get("cost_usd") or 0.0)
        for r in rows
        if r.get("session_id") == session_id
    )
    return total / (WINDOW_RATE_SECONDS / 60.0)


def current_turn_cost_usd(session_id: str, since_ts: float) -> float:
    rows = ledger_since(since_ts)
    return sum(
        float(r.get("cost_usd") or 0.0)
        for r in rows
        if r.get("session_id") == session_id
    )


# --- audit log --------------------------------------------------------------

def mark_halt(session_id: str, reason: str) -> None:
    """Mark this session as currently halted so the indicator can show
    `Cost Guard (HALTED)` in the header until the user submits a non-bypass
    prompt (which signals the user has acknowledged and resolved it)."""
    if not session_id:
        return
    try:
        session_update(
            session_id,
            last_halt={"ts": time.time(), "reason": reason},
        )
    except Exception:
        pass


def clear_halt(session_id: str) -> None:
    if not session_id:
        return
    try:
        state = session_load(session_id)
        if state.pop("last_halt", None) is not None:
            session_save(session_id, state)
    except Exception:
        pass


def _halt_reason_human(reason: str) -> str:
    return {
        "session-over-cap": "session cap reached",
        "rate-over-limit": "burn rate over limit",
        "step-over-cap": "step exceeded cap",
        "subagent-cap": "subagent fan-out cap reached",
    }.get(reason, reason or "limit exceeded")


def log_decision(decision: str, reason: str, event: str, session_id: str, extras: Dict[str, Any]) -> None:
    cfg = load_config()
    if not cfg.get("log_decisions", True):
        return
    try:
        _append_jsonl(HALT_LOG, {
            "ts": datetime.now(timezone.utc).isoformat(),
            "decision": decision,
            "event": event,
            "session_id": session_id,
            "reason": reason,
            **extras,
        })
    except Exception:
        pass


# --- halt banner ------------------------------------------------------------

def halt_banner(trigger: str, detail: str, cfg: Dict[str, Any], session_id: str) -> str:
    sess_cost = session_cost_usd(session_id)
    sess_rate = session_rate_per_min_usd(session_id)
    cap = cfg.get("max_usd_per_session", 10.0)
    return (
        "\n"
        "cost-guard: HALTED — cost protection triggered\n"
        "-----------------------------------------------\n"
        f"Trigger:   {trigger}\n"
        f"Detail:    {detail}\n"
        f"Session:   ${sess_cost:.2f} spent  ·  rate ${sess_rate:.2f}/min  ·  cap ${cap:.2f}\n"
        "\n"
        "Options:\n"
        "  /cost-guard:set-session-limit 20   — raise this session's cap (USD)\n"
        "  /cost-guard:set-step-limit 5       — raise the per-step cap (USD)\n"
        "  /cost-guard:set-rate 1.00          — raise the burn rate limit (USD/min)\n"
        "  /cost-guard:pause                  — disable halts globally\n"
        "  /cost-guard:status                 — full report\n"
        "  /exit                              — end session\n"
    )


# --- hook dispatch ----------------------------------------------------------

def read_hook_input() -> Dict[str, Any]:
    try:
        data = sys.stdin.read()
        if not data:
            return {}
        return json.loads(data)
    except Exception:
        return {}


def ingest_transcript(payload: Dict[str, Any], session_id: str) -> None:
    tp = payload.get("transcript_path")
    if not tp:
        return
    sess = session_load(session_id)
    last_ts = float(sess.get("last_ingested_ts") or 0.0)
    latest = last_ts
    for ts, model, cost in parse_transcript(tp, since_ts=last_ts if last_ts > 0 else None):
        if ts <= last_ts or cost <= 0:
            continue
        ledger_append(ts, session_id, model, cost, origin="main")
        if ts > latest:
            latest = ts
    try:
        for sub in subagent_transcripts_for(tp):
            for ts, model, cost in parse_transcript(sub, since_ts=last_ts if last_ts > 0 else None):
                if ts <= last_ts or cost <= 0:
                    continue
                ledger_append(ts, session_id, model, cost, origin="sub")
                if ts > latest:
                    latest = ts
    except Exception:
        pass
    if latest > last_ts:
        session_update(session_id, last_ingested_ts=latest)


def cmd_halt_check() -> int:
    payload = read_hook_input()
    cfg = load_config()
    event = payload.get("hook_event_name") or ""
    session_id = payload.get("session_id") or "unknown"

    try:
        ingest_transcript(payload, session_id)
    except Exception:
        pass

    if not cfg.get("enabled", True):
        return 0

    sess = session_load(session_id)
    if sess.get("paused"):
        return 0

    if event == "SessionStart":
        return handle_session_start(payload, session_id, cfg)
    if event == "UserPromptSubmit":
        return handle_user_prompt(payload, session_id, cfg)
    if event == "PreToolUse":
        return handle_pre_tool(payload, session_id, cfg)
    if event == "PostToolBatch":
        return handle_post_batch(payload, session_id, cfg)
    if event == "PreCompact":
        return handle_pre_compact(payload, session_id, cfg)
    if event == "SubagentStart":
        return 0
    return 0


def handle_session_start(payload: Dict[str, Any], session_id: str, cfg: Dict[str, Any]) -> int:
    _ensure_data_dir()
    ledger_compact()

    if cfg.get("seed_from_history", True):
        try:
            seed_from_history()
        except Exception:
            pass

    session_update(
        session_id,
        started_at=time.time(),
        turn_start_ts=time.time(),
        subagent_spawns_this_turn=0,
        last_ingested_ts=0.0,
    )

    # If cost-guard owns the bottom-row indicator and the install path has
    # drifted (e.g., post-plugin-update), rewrite to the current path so the
    # user doesn't have to re-run install-indicator.
    try:
        _heal_indicator_path()
    except Exception:
        pass

    cap = cfg.get("max_usd_per_session", 10.0)
    turn_cap = cfg.get("max_usd_per_step", 2.0)
    rate = cfg.get("rate_per_min_usd", 0.5)
    sys.stdout.write(
        f"cost-guard active: session cap ${cap:.2f}, "
        f"step cap ${turn_cap:.2f}, rate limit ${rate:.2f}/min.\n"
    )
    return 0


def handle_user_prompt(payload: Dict[str, Any], session_id: str, cfg: Dict[str, Any]) -> int:
    session_update(session_id, turn_start_ts=time.time(), subagent_spawns_this_turn=0)

    # Escape hatches: cost-guard's own slash commands and /exit must never be
    # blocked — they are how the user unblocks a halted session.
    prompt = (
        payload.get("prompt")
        or payload.get("user_prompt")
        or payload.get("input")
        or ""
    )
    prompt_head = prompt.strip().split(maxsplit=1)[0] if prompt.strip() else ""
    if prompt_head.startswith("/cost-guard:") or prompt_head in ("/exit", "/quit"):
        return 0

    # Submitting a regular prompt = the user has acknowledged any prior halt
    # state and is engaging with new work. Clear the HALTED indicator badge
    # so it doesn't linger after the user has resolved the cause.
    clear_halt(session_id)

    # Only gate NEW prompts on session-over-cap. Rate and per-step caps are
    # about cost-inside-a-step, not about whether to start one; they are
    # enforced on PostToolBatch / PreToolUse where they belong. Blocking
    # UserPromptSubmit on rate leaves the user stuck — their last 5 min of
    # burn lingers even while they're reading the halt banner.
    session_cap = float(cfg.get("max_usd_per_session", 10.0))
    warn_usd = float(cfg.get("warn_at_usd", 7.0))
    sess_cost = session_cost_usd(session_id)

    if sess_cost >= session_cap:
        sys.stderr.write(halt_banner(
            trigger=f"session spend ${sess_cost:.2f} >= cap ${session_cap:.2f}",
            detail="This session has reached its total USD cap.",
            cfg=cfg,
            session_id=session_id,
        ))
        log_decision(
            "halt", "session-over-cap", "UserPromptSubmit", session_id,
            {"session_cost": sess_cost, "cap": session_cap},
        )
        mark_halt(session_id, "session-over-cap")
        return 2

    if warn_usd <= sess_cost < session_cap:
        sys.stdout.write(
            f"cost-guard warning: session spend ${sess_cost:.2f} "
            f"(warn ${warn_usd:.2f}, cap ${session_cap:.2f}).\n"
        )
        log_decision(
            "warn", "session-warn", "UserPromptSubmit", session_id,
            {"session_cost": sess_cost, "warn": warn_usd, "cap": session_cap},
        )

    return 0


def handle_pre_tool(payload: Dict[str, Any], session_id: str, cfg: Dict[str, Any]) -> int:
    state = session_load(session_id)
    spawns = int(state.get("subagent_spawns_this_turn") or 0)
    max_spawns = int(cfg.get("max_subagent_spawns_per_step", 8))

    if spawns >= max_spawns:
        sys.stderr.write(halt_banner(
            trigger=f"subagent fan-out cap reached ({spawns} spawns this step, limit {max_spawns})",
            detail="Further Agent/Task spawns denied for this step. Start a new step to reset.",
            cfg=cfg,
            session_id=session_id,
        ))
        log_decision("deny", "subagent-cap", "PreToolUse", session_id, {"spawns": spawns, "max": max_spawns})
        mark_halt(session_id, "subagent-cap")
        return 2

    rc = evaluate_and_maybe_halt(
        session_id=session_id, event="PreToolUse", cfg=cfg, check_turn_cost=False,
    )
    if rc == 2:
        return 2

    session_update(session_id, subagent_spawns_this_turn=spawns + 1)
    return 0


def handle_post_batch(payload: Dict[str, Any], session_id: str, cfg: Dict[str, Any]) -> int:
    return evaluate_and_maybe_halt(
        session_id=session_id, event="PostToolBatch", cfg=cfg, check_turn_cost=True,
    )


def handle_pre_compact(payload: Dict[str, Any], session_id: str, cfg: Dict[str, Any]) -> int:
    return evaluate_and_maybe_halt(
        session_id=session_id, event="PreCompact", cfg=cfg, check_turn_cost=False,
    )


def evaluate_and_maybe_halt(
    *, session_id: str, event: str, cfg: Dict[str, Any], check_turn_cost: bool,
) -> int:
    session_cap = float(cfg.get("max_usd_per_session", 10.0))
    turn_cap = float(cfg.get("max_usd_per_step", 2.0))
    rate_limit = float(cfg.get("rate_per_min_usd", 0.5))
    warn_usd = float(cfg.get("warn_at_usd", 7.0))

    sess_cost = session_cost_usd(session_id)
    sess_rate = session_rate_per_min_usd(session_id)

    # --- Halt 1: per-session $ cap ---
    if sess_cost >= session_cap:
        sys.stderr.write(halt_banner(
            trigger=f"session spend ${sess_cost:.2f} >= cap ${session_cap:.2f}",
            detail="This session has reached its total USD cap.",
            cfg=cfg,
            session_id=session_id,
        ))
        log_decision(
            "halt", "session-over-cap", event, session_id,
            {"session_cost": sess_cost, "cap": session_cap},
        )
        mark_halt(session_id, "session-over-cap")
        return 2

    # --- Halt 2: burn rate ---
    if sess_rate >= rate_limit:
        sys.stderr.write(halt_banner(
            trigger=f"session burn rate ${sess_rate:.2f}/min >= limit ${rate_limit:.2f}/min",
            detail="Trailing 5-minute burn rate exceeds the configured limit.",
            cfg=cfg,
            session_id=session_id,
        ))
        log_decision(
            "halt", "rate-over-limit", event, session_id,
            {"rate": sess_rate, "limit": rate_limit},
        )
        mark_halt(session_id, "rate-over-limit")
        return 2

    # --- Halt 3: per-step $ cap (only at PostToolBatch) ---
    if check_turn_cost:
        state = session_load(session_id)
        turn_start = float(state.get("turn_start_ts") or time.time())
        turn_cost = current_turn_cost_usd(session_id, turn_start)
        if turn_cost >= turn_cap:
            sys.stderr.write(halt_banner(
                trigger=f"step cost ${turn_cost:.2f} >= per-step cap ${turn_cap:.2f}",
                detail="One step has exceeded the per-step hard cap.",
                cfg=cfg,
                session_id=session_id,
            ))
            log_decision(
                "halt", "step-over-cap", event, session_id,
                {"turn_cost": turn_cost, "cap": turn_cap},
            )
            mark_halt(session_id, "step-over-cap")
            return 2

    # --- Warn (amber): session approaching cap ---
    if (
        sess_cost >= warn_usd
        and sess_cost < session_cap
        and event in ("UserPromptSubmit", "SessionStart")
    ):
        sys.stdout.write(
            f"cost-guard warning: session spend ${sess_cost:.2f} "
            f"(warn ${warn_usd:.2f}, cap ${session_cap:.2f}).\n"
        )
        log_decision(
            "warn", "session-warn", event, session_id,
            {"session_cost": sess_cost, "warn": warn_usd, "cap": session_cap},
        )

    return 0


# --- user-facing subcommands ------------------------------------------------

def cmd_status(args: argparse.Namespace) -> int:
    cfg = load_config()

    # Infer "current session" from session state files: pick the most recently
    # modified one, which corresponds to the live Claude Code session we're
    # reporting for. If none exists, session metrics show as unknown.
    session_id = _latest_session_id()
    sess_rate = session_rate_per_min_usd(session_id) if session_id else 0.0
    sess_spent = session_cost_usd(session_id) if session_id else 0.0
    global_spent = global_5h_cost_usd()

    out = {
        "enabled": cfg.get("enabled"),
        "config": {
            "max_usd_per_session": cfg.get("max_usd_per_session"),
            "max_usd_per_step": cfg.get("max_usd_per_step"),
            "rate_per_min_usd": cfg.get("rate_per_min_usd"),
            "max_subagent_spawns_per_step": cfg.get("max_subagent_spawns_per_step"),
            "warn_at_usd": cfg.get("warn_at_usd"),
        },
        "session": {
            "session_id": session_id,
            "spent_usd": round(sess_spent, 4),
            "rate_per_min_usd": round(sess_rate, 4),
        },
        "all_sessions_spent_usd_5h": round(global_spent, 4),
        "paths": {
            "plugin_root": str(PLUGIN_ROOT),
            "plugin_data": str(PLUGIN_DATA),
            "cost_ledger": str(COST_LEDGER),
            "overrides": str(OVERRIDES),
            "halt_log": str(HALT_LOG),
        },
    }
    if args.json:
        sys.stdout.write(json.dumps(out, indent=2) + "\n")
    else:
        print("cost-guard status")
        print("-----------------")
        print(f"enabled:                     {out['enabled']}")
        print("")
        print("-- this session --")
        print(f"session id:                  {session_id or '—'}")
        print(f"session spent:               ${sess_spent:.2f}  (cap ${cfg.get('max_usd_per_session')}, warn ${cfg.get('warn_at_usd')})")
        print(f"session burn rate (5 min):   ${sess_rate:.2f}/min  (limit ${cfg.get('rate_per_min_usd')})")
        print("")
        print("-- caps --")
        print(f"per-step USD cap:           ${cfg.get('max_usd_per_step')}")
        print(f"subagent spawns per step:   {cfg.get('max_subagent_spawns_per_step')}")
        print("")
        print(f"all sessions spent (last 5h): ${out['all_sessions_spent_usd_5h']:.2f}")
    return 0


def _latest_session_id() -> Optional[str]:
    """Return the session_id of the most recently touched session state file."""
    if not SESSIONS_DIR.is_dir():
        return None
    candidates: List[Tuple[float, Path]] = []
    try:
        for p in SESSIONS_DIR.glob("*.json"):
            try:
                candidates.append((p.stat().st_mtime, p))
            except OSError:
                continue
    except Exception:
        return None
    if not candidates:
        return None
    candidates.sort(reverse=True)
    return candidates[0][1].stem


def cmd_set_session_limit(args: argparse.Namespace) -> int:
    try:
        value = float(args.value)
    except (ValueError, TypeError):
        sys.stderr.write(f"invalid value: {args.value!r}\n")
        return 1
    if value < 0.1:
        sys.stderr.write("max_usd_per_session must be >= 0.10\n")
        return 1
    set_override("max_usd_per_session", value)
    print(f"cost-guard: max_usd_per_session set to ${value:.2f}")
    return 0


def cmd_set_step_limit(args: argparse.Namespace) -> int:
    try:
        value = float(args.value)
    except (ValueError, TypeError):
        sys.stderr.write(f"invalid value: {args.value!r}\n")
        return 1
    if value < 0.05:
        sys.stderr.write("max_usd_per_step must be >= 0.05\n")
        return 1
    set_override("max_usd_per_step", value)
    print(f"cost-guard: max_usd_per_step set to ${value:.2f}")
    return 0


def cmd_set_rate(args: argparse.Namespace) -> int:
    try:
        value = float(args.value)
    except (ValueError, TypeError):
        sys.stderr.write(f"invalid rate value: {args.value!r}\n")
        return 1
    if value < 0.01:
        sys.stderr.write("rate_per_min_usd must be >= 0.01\n")
        return 1
    set_override("rate_per_min_usd", value)
    print(f"cost-guard: rate_per_min_usd set to ${value:.2f}/min")
    return 0


def cmd_pause(args: argparse.Namespace) -> int:
    if not args.session_id:
        set_override("enabled", False)
        print("cost-guard: globally disabled. Re-enable with /cost-guard:resume.")
        return 0
    session_update(args.session_id, paused=True)
    print(f"cost-guard: paused for session {args.session_id}.")
    return 0


def cmd_resume(args: argparse.Namespace) -> int:
    if not args.session_id:
        set_override("enabled", True)
        print("cost-guard: globally enabled.")
        return 0
    session_update(args.session_id, paused=False)
    print(f"cost-guard: resumed for session {args.session_id}.")
    return 0


def cmd_set_subagent_cap(args: argparse.Namespace) -> int:
    try:
        value = int(float(args.value))
    except (ValueError, TypeError):
        sys.stderr.write(f"invalid value: {args.value!r}\n")
        return 1
    if not (1 <= value <= 100):
        sys.stderr.write("max_subagent_spawns_per_step must be between 1 and 100\n")
        return 1
    set_override("max_subagent_spawns_per_step", value)
    print(f"cost-guard: max_subagent_spawns_per_step set to {value}")
    return 0


def cmd_set_warn(args: argparse.Namespace) -> int:
    try:
        value = float(args.value)
    except (ValueError, TypeError):
        sys.stderr.write(f"invalid value: {args.value!r}\n")
        return 1
    if value < 0.05:
        sys.stderr.write("warn_at_usd must be >= 0.05\n")
        return 1
    set_override("warn_at_usd", value)
    print(f"cost-guard: warn_at_usd set to ${value:.2f}")
    return 0


# --- bottom-row indicator ---------------------------------------------------
#
# Claude Code has exactly one `statusLine` field in ~/.claude/settings.json
# that drives the bottom row. `install-indicator` writes that field to point
# at `cost-guard indicator`, optionally preserving whatever command was there
# before so the existing content keeps rendering above cost-guard's row.

_USER_SETTINGS = Path.home() / ".claude" / "settings.json"

# Backup of indicator state outside ${CLAUDE_PLUGIN_DATA}, so that wiping
# the plugin data directory does not destroy the wrapped-command stash that
# the indicator wrapper depends on. Lives next to settings.json in the
# user's persistent config dir.
_INDICATOR_BACKUP = Path.home() / ".claude" / "cost-guard-indicator-backup.json"


def _indicator_command() -> str:
    return f"{PLUGIN_ROOT / 'bin' / 'cost-guard'} indicator"


def _is_cost_guard_indicator(entry: Dict[str, Any]) -> bool:
    cmd = entry.get("command") or ""
    return "cost-guard" in cmd and cmd.rstrip().endswith(" indicator")


def _indicator_state_read() -> Dict[str, Any]:
    """Read indicator state. Falls back to the backup outside PLUGIN_DATA when
    the primary file is missing — covers the case where the user wipes the
    plugin data directory but still has cost-guard installed as the bottom-row
    command. Without the fallback, the wrapper would silently drop their
    wrapped statusline."""
    primary = _read_json(INDICATOR_STATE, None)
    if isinstance(primary, dict) and primary:
        return primary
    backup = _read_json(_INDICATOR_BACKUP, None)
    if isinstance(backup, dict) and backup:
        # Restore the primary so subsequent reads stay fast and a manual
        # inspection of PLUGIN_DATA shows accurate state.
        try:
            _write_json_atomic(INDICATOR_STATE, backup)
        except Exception:
            pass
        return backup
    return {}


def _indicator_state_write(data: Dict[str, Any]) -> None:
    _ensure_data_dir()
    if data:
        _write_json_atomic(INDICATOR_STATE, data)
        # Mirror to backup so plugin-data wipes don't destroy the stash.
        try:
            _write_json_atomic(_INDICATOR_BACKUP, data)
        except Exception:
            pass
    else:
        for p in (INDICATOR_STATE, _INDICATOR_BACKUP):
            try:
                p.unlink()
            except FileNotFoundError:
                pass


def _render_cost_guard_row(payload: Dict[str, Any]) -> str:
    cfg = load_config()
    session_id = payload.get("session_id") or ""
    sess_cost = session_cost_usd(session_id)
    sess_rate = session_rate_per_min_usd(session_id)
    session_cap = float(cfg.get("max_usd_per_session", 10.0))
    warn_usd = float(cfg.get("warn_at_usd", 7.0))
    rate_limit = float(cfg.get("rate_per_min_usd", 0.5))
    turn_cap = float(cfg.get("max_usd_per_step", 2.0))

    sess_state = session_load(session_id) if session_id else {}
    turn_start = float(sess_state.get("turn_start_ts") or time.time())
    turn_cost = current_turn_cost_usd(session_id, turn_start) if session_id else 0.0

    # Context window percentage (from statusline stdin — pre-computed by Claude Code).
    ctx_pct: Optional[float]
    try:
        ctx_pct = float(payload.get("context_window", {}).get("used_percentage"))
    except (TypeError, ValueError):
        ctx_pct = None

    # 5-hour slot percentage (Pro/Max only). Capture start/latest for estimate.
    slot_latest_pct: Optional[float]
    try:
        slot_latest_pct = float(
            payload.get("rate_limits", {}).get("five_hour", {}).get("used_percentage")
        )
    except (TypeError, ValueError):
        slot_latest_pct = None

    if session_id and slot_latest_pct is not None:
        dirty = False
        if sess_state.get("slot_start_percent") is None:
            sess_state["slot_start_percent"] = slot_latest_pct
            dirty = True
        prev = sess_state.get("slot_latest_percent")
        if prev is None or prev != slot_latest_pct:
            sess_state["slot_latest_percent"] = slot_latest_pct
            dirty = True
        if dirty:
            session_save(session_id, sess_state)

    # Estimated full-slot USD capacity, and cumulative USD burned in the slot.
    # Computed as soon as the session has done meaningful work AND moved the
    # slot at least slightly (>= $0.05 spent AND >= 0.1% slot movement). Below
    # those, the ratio is too noisy to be useful.
    slot_start_pct = sess_state.get("slot_start_percent")
    est_slot_cap: Optional[float] = None
    slot_used_usd: Optional[float] = None
    if (
        slot_start_pct is not None
        and slot_latest_pct is not None
        and sess_cost >= 0.05
    ):
        slot_share = float(slot_latest_pct) - float(slot_start_pct)
        if slot_share >= 0.1:
            est_slot_cap = sess_cost / (slot_share / 100.0)
            slot_used_usd = est_slot_cap * (float(slot_latest_pct) / 100.0)

    RESET = "\033[0m"
    BOLD = "\033[1m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    RED = "\033[31m"
    DIM = "\033[2m"
    # OGGEH brand pink #ec638d, expressed as ANSI true-color (24-bit) escape.
    # Modern terminals (iTerm2, Terminal.app, Windows Terminal, modern Linux
    # terminals) support this directly. On legacy 16-color terminals it
    # gracefully falls back to no-color.
    BRAND = "\033[38;2;236;99;141m"

    def c_spent(s: float) -> str:
        if s >= session_cap:
            return RED
        if s >= warn_usd:
            return YELLOW
        return GREEN

    def c_rate(r: float) -> str:
        if r >= rate_limit:
            return RED
        if r >= rate_limit * 0.7:
            return YELLOW
        return GREEN

    def c_turn(t: float) -> str:
        if t >= turn_cap:
            return RED
        if t >= turn_cap * 0.7:
            return YELLOW
        return GREEN

    def c_ctx(p: float) -> str:
        if p >= 90:
            return RED
        if p >= 70:
            return YELLOW
        return GREEN

    paused = bool(sess_state.get("paused"))
    enabled = cfg.get("enabled", True)
    last_halt = sess_state.get("last_halt") or {}
    halt_reason = last_halt.get("reason") if isinstance(last_halt, dict) else None

    # --- Header line ---
    # Priority: disabled > paused > halted > active.
    # `(HALTED)` clears on the next non-bypass UserPromptSubmit (see
    # handle_user_prompt) so the badge doesn't linger after the user has
    # acknowledged and resolved the cause.
    if not enabled:
        header = (
            f"{DIM}{BOLD}Cost Guard (off){RESET}"
            f"{DIM} — runaway protection disabled{RESET}"
        )
    elif paused:
        header = (
            f"{YELLOW}{BOLD}Cost Guard (paused){RESET}"
            f"{DIM} — halts disabled for this session{RESET}"
        )
    elif halt_reason:
        header = (
            f"{RED}{BOLD}Cost Guard (HALTED){RESET}"
            f"{DIM} — {_halt_reason_human(halt_reason)}{RESET}"
        )
    else:
        header = (
            f"{BRAND}{BOLD}Cost Guard{RESET}"
            f"{DIM} — token-cost watchdog{RESET}"
        )

    # --- Metric cells (icon + label + value + threshold) ---
    m_session = (
        f"💵 session: {c_spent(sess_cost)}${sess_cost:.2f}{RESET}"
        f" (cap ${session_cap:.2f})"
    )
    m_rate = (
        f"🔥 rate: {c_rate(sess_rate)}${sess_rate:.2f}/min{RESET}"
        f" (limit ${rate_limit:.2f})"
    )
    m_step = (
        f"👣 step: {c_turn(turn_cost)}${turn_cost:.2f}{RESET}"
        f" (cap ${turn_cap:.2f})"
    )
    m_ctx = ""
    if ctx_pct is not None:
        m_ctx = f"🧠 ctx: {c_ctx(ctx_pct)}{ctx_pct:.0f}%{RESET}"

    m_slot = ""
    if slot_latest_pct is not None:
        if slot_used_usd is not None and est_slot_cap is not None:
            m_slot = (
                f"🎰 slot: ${slot_used_usd:.2f} of ≈${est_slot_cap:.2f} plan"
                f" ({slot_latest_pct:.0f}%)"
            )
        else:
            # USD estimate not yet computable; keep the cell tight so it
            # doesn't blow out the column width. Detail is in /cost-guard:status.
            m_slot = (
                f"🎰 slot: {slot_latest_pct:.0f}%"
                f"{DIM} (calibrating){RESET}"
            )

    # --- Layout: 3 columns. Line 2 = (session, rate, step). Line 3 = (ctx, slot, _).
    # Each column padded to max(visual_width(top), visual_width(bottom)) + GAP
    # so labels on line 3 align under labels on line 2.
    GAP = 4
    columns = [(m_session, m_ctx), (m_rate, m_slot), (m_step, "")]
    widths = [max(_visual_width(t), _visual_width(b)) for t, b in columns]

    line2 = "".join(
        _pad_visual(t, w + GAP) for (t, _), w in zip(columns, widths)
    ).rstrip()
    line3 = "".join(
        _pad_visual(b, w + GAP) for (_, b), w in zip(columns, widths)
    ).rstrip()

    out = [header, line2]
    if line3:
        out.append(line3)
    return "\n".join(out)


# --- visual-width helpers (used by the indicator layout) ---------------------

_ANSI_RE = re.compile(r"\033\[[0-9;]*m")


def _visual_width(s: str) -> int:
    """Approximate terminal display width: emoji = 2 cells, ASCII = 1.

    Strips ANSI color codes first (they don't take screen columns). Treats
    codepoints commonly used as wide emoji as 2 cells. This is an
    approximation — exact width is terminal-dependent — but it's correct
    in practice for iTerm2, Terminal.app, and modern Linux terminals
    rendering the emoji set used by cost-guard's indicator (💵 🔥 👣 🧠 🎰).
    """
    plain = _ANSI_RE.sub("", s)
    width = 0
    for ch in plain:
        cp = ord(ch)
        # Emoji block (1F300+) and miscellaneous symbols (2600..26FF) render
        # as 2 cells in most terminals.
        if cp >= 0x1F300 or 0x2600 <= cp < 0x2700:
            width += 2
        else:
            width += 1
    return width


def _pad_visual(s: str, target_width: int) -> str:
    pad = target_width - _visual_width(s)
    if pad <= 0:
        return s
    return s + (" " * pad)


def cmd_indicator() -> int:
    """Render the bottom-row indicator. Called by Claude Code every refresh.

    Reads the session JSON on stdin. If install was run in `compose` mode,
    first runs the previously-configured command with the same stdin and
    echoes its stdout verbatim; then prints cost-guard's row below.
    """
    try:
        data = sys.stdin.read()
        payload = json.loads(data) if data else {}
    except Exception:
        data = ""
        payload = {}

    state = _indicator_state_read()
    wrapped = state.get("wrapped_command")

    if wrapped:
        try:
            result = subprocess.run(
                wrapped,
                shell=True,
                input=data,
                capture_output=True,
                text=True,
                timeout=8,
            )
            out = result.stdout or ""
            if out:
                sys.stdout.write(out)
                if not out.endswith("\n"):
                    sys.stdout.write("\n")
        except Exception:
            pass

    sys.stdout.write(_render_cost_guard_row(payload) + "\n")
    return 0


def cmd_install_indicator(args: argparse.Namespace) -> int:
    path = _USER_SETTINGS
    path.parent.mkdir(parents=True, exist_ok=True)
    settings = _read_json(path, {}) or {}
    if not isinstance(settings, dict):
        sys.stderr.write(f"cost-guard: {path} is not a JSON object; aborting.\n")
        return 1

    existing = settings.get("statusLine") or {}
    desired = _indicator_command()
    mode = (getattr(args, "mode", None) or "").lower().strip()

    # Case A: already cost-guard → heal the path if it has drifted.
    if isinstance(existing, dict) and _is_cost_guard_indicator(existing):
        if existing.get("command") == desired:
            print(f"cost-guard: indicator already installed -> {path}")
            return 0
        settings["statusLine"] = dict(existing)
        settings["statusLine"]["command"] = desired
        _write_json_atomic(path, settings)
        print(f"cost-guard: indicator path updated in {path}")
        return 0

    # Case B: a non-cost-guard bottom-row command is already configured.
    if isinstance(existing, dict) and existing.get("command"):
        existing_cmd = existing.get("command")
        if not mode:
            sys.stdout.write(
                f"Your ~/.claude/settings.json already has a bottom-row command configured:\n"
                f"    {existing_cmd}\n"
                f"\n"
                f"Would you like to:\n"
                f"\n"
                f"  1. Keep it and augment — cost-guard runs your existing command and\n"
                f"     appends its own row below it. Your current content is preserved.\n"
                f"     Run:  /cost-guard:install-indicator compose\n"
                f"\n"
                f"  2. Replace it — cost-guard takes over. Your existing command is\n"
                f"     backed up and restored on /cost-guard:uninstall-indicator.\n"
                f"     Run:  /cost-guard:install-indicator replace\n"
            )
            return 0

        if mode not in ("compose", "replace"):
            sys.stderr.write(
                f"cost-guard: unknown mode {mode!r}. Valid modes: compose, replace.\n"
            )
            return 1

        _indicator_state_write({
            "mode": mode,
            "wrapped_command": existing_cmd if mode == "compose" else None,
            "previous_entry": existing,
        })
        settings["statusLine"] = {
            "type": "command",
            "command": desired,
            "refreshInterval": existing.get("refreshInterval", 2),
        }
        _write_json_atomic(path, settings)

        if mode == "compose":
            print(f"cost-guard: indicator installed in compose mode.")
            print(f"  Your existing command runs first; cost-guard's row appears below.")
            print(f"  Wrapped: {existing_cmd}")
        else:
            print(f"cost-guard: indicator installed (replaced the existing command).")
            print(f"  Previous command backed up for restore: {existing_cmd}")
        print(f"  Settings file: {path}")
        print(f"  Revert with /cost-guard:uninstall-indicator.")
        print(f"  Restart Claude Code (or reload settings) to see the change.")
        return 0

    # Case C: nothing in the slot — install solo.
    _indicator_state_write({"mode": "solo"})
    settings["statusLine"] = {
        "type": "command",
        "command": desired,
        "refreshInterval": 2,
    }
    _write_json_atomic(path, settings)
    print(f"cost-guard: indicator installed (no prior bottom-row command was present).")
    print(f"  Settings file: {path}")
    print(f"  Revert with /cost-guard:uninstall-indicator.")
    print(f"  Restart Claude Code to see it.")
    return 0


def cmd_uninstall_indicator(args: argparse.Namespace) -> int:
    path = _USER_SETTINGS
    settings = _read_json(path, {}) or {}
    if not isinstance(settings, dict):
        sys.stderr.write(f"cost-guard: {path} is not a JSON object; aborting.\n")
        return 1
    entry = settings.get("statusLine") or {}
    if not isinstance(entry, dict) or not _is_cost_guard_indicator(entry):
        print("cost-guard: no cost-guard indicator installed; nothing to do.")
        return 0

    state = _indicator_state_read()
    previous = state.get("previous_entry")
    if isinstance(previous, dict) and previous:
        settings["statusLine"] = previous
        _write_json_atomic(path, settings)
        _indicator_state_write({})
        print(f"cost-guard: indicator uninstalled; restored your previous bottom-row command:")
        print(f"  {previous.get('command')}")
        return 0

    # Solo install, or nothing to restore.
    settings.pop("statusLine", None)
    _write_json_atomic(path, settings)
    _indicator_state_write({})
    print(f"cost-guard: indicator uninstalled. There was no prior command to restore.")
    return 0


def _heal_indicator_path() -> None:
    """On SessionStart, rewrite our own indicator entry if PLUGIN_ROOT drifted.
    Never touches entries that don't belong to cost-guard."""
    path = _USER_SETTINGS
    settings = _read_json(path, None)
    if not isinstance(settings, dict):
        return
    entry = settings.get("statusLine")
    if not isinstance(entry, dict) or not _is_cost_guard_indicator(entry):
        return
    desired = _indicator_command()
    if entry.get("command") == desired:
        return
    entry["command"] = desired
    settings["statusLine"] = entry
    _write_json_atomic(path, settings)


# --- diagnostics ------------------------------------------------------------

def cmd_diag(args: argparse.Namespace) -> int:
    """Dump plugin state for debugging — files, sizes, env, recent halts."""
    lines: List[str] = []
    lines.append("cost-guard diagnostics")
    lines.append("=" * 60)
    lines.append(f"PLUGIN_ROOT    = {PLUGIN_ROOT}  (exists: {PLUGIN_ROOT.is_dir()})")
    lines.append(f"PLUGIN_DATA    = {PLUGIN_DATA}  (exists: {PLUGIN_DATA.is_dir()})")
    lines.append("")
    lines.append("env:")
    for k in ("CLAUDE_PLUGIN_ROOT", "CLAUDE_PLUGIN_DATA"):
        lines.append(f"  {k} = {os.environ.get(k, '(unset)')}")
    for k in sorted(os.environ):
        if k.startswith("CLAUDE_PLUGIN_OPTION_"):
            lines.append(f"  {k} = {os.environ[k]}")
    lines.append("")
    lines.append("data files:")
    for name, p in [
        ("pricing.json", PRICING_FILE),
        ("cost-ledger.jsonl", COST_LEDGER),
        ("overrides.json", OVERRIDES),
        ("halt-log.jsonl", HALT_LOG),
        (".seeded", SEED_MARKER),
        ("indicator.json", INDICATOR_STATE),
        ("cost-guard-indicator-backup.json (~/.claude/)", _INDICATOR_BACKUP),
    ]:
        if p.exists():
            try:
                size = p.stat().st_size
            except OSError:
                size = -1
            lines.append(f"  {name}: {size} bytes")
        else:
            lines.append(f"  {name}: MISSING")

    # sessions
    if SESSIONS_DIR.is_dir():
        try:
            sess_files = sorted(SESSIONS_DIR.glob("*.json"))
        except Exception:
            sess_files = []
        lines.append(f"  sessions/: {len(sess_files)} file(s)")
        for sf in sess_files[-5:]:
            try:
                mtime = time.strftime("%H:%M:%S", time.localtime(sf.stat().st_mtime))
            except OSError:
                mtime = "?"
            lines.append(f"    - {sf.name}  ({mtime})")
    else:
        lines.append(f"  sessions/: MISSING")

    # recent halt entries
    lines.append("")
    lines.append("last 5 halt-log entries:")
    if HALT_LOG.exists():
        try:
            raw = HALT_LOG.read_text().strip().splitlines()
            entries = []
            for ln in raw[-5:]:
                try:
                    entries.append(json.loads(ln))
                except Exception:
                    entries.append({"raw": ln})
            for e in entries:
                ts = e.get("ts", "")
                dec = e.get("decision", "")
                ev = e.get("event", "")
                reason = e.get("reason", "")
                lines.append(f"  [{ts}] {dec} {ev}: {reason}")
        except Exception as exc:
            lines.append(f"  (read error: {exc})")
    else:
        lines.append("  (no halt-log file)")

    # current config
    cfg = load_config()
    lines.append("")
    lines.append("effective config:")
    for k, v in cfg.items():
        lines.append(f"  {k} = {v}")

    # indicator state
    state = _indicator_state_read()
    lines.append("")
    lines.append(f"indicator state: {state or '(none)'}")
    if _USER_SETTINGS.exists():
        try:
            us = _read_json(_USER_SETTINGS, {}) or {}
            sl = us.get("statusLine") if isinstance(us, dict) else None
            lines.append(f"~/.claude/settings.json bottom-row command: {sl.get('command') if isinstance(sl, dict) else '(none)'}")
        except Exception as exc:
            lines.append(f"~/.claude/settings.json read error: {exc}")
    else:
        lines.append(f"~/.claude/settings.json: not found")

    sys.stdout.write("\n".join(lines) + "\n")
    return 0


# --- argparse wiring --------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="cost-guard",
        description="USD budget enforcement for Claude Code.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("halt-check", help="(internal) hook dispatcher")
    sub.add_parser("indicator", help="(internal) render the bottom-row indicator")

    sp_status = sub.add_parser("status", help="Print current session spend, rate, and caps.")
    sp_status.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")

    sub.add_parser("diag", help="Dump plugin state for debugging.")

    sp_ss = sub.add_parser("set-session-limit", help="Set per-session USD cap.")
    sp_ss.add_argument("value", help="New session cap in USD.")

    sp_st = sub.add_parser("set-step-limit", help="Set per-step USD cap.")
    sp_st.add_argument("value", help="New per-step cap in USD.")

    sp_sr = sub.add_parser("set-rate", help="Set burn-rate limit (USD/min).")
    sp_sr.add_argument("value", help="New rate limit in USD/min.")

    sp_sc = sub.add_parser("set-subagent-cap", help="Set max subagent spawns per step.")
    sp_sc.add_argument("value", help="New subagent-spawn cap (1-100).")

    sp_sw = sub.add_parser("set-warn", help="Set the amber-warn threshold (USD).")
    sp_sw.add_argument("value", help="New warn threshold in USD.")

    sp_p = sub.add_parser("pause", help="Pause halting for this session (or globally).")
    sp_p.add_argument("--session-id", default=None)

    sp_r = sub.add_parser("resume", help="Resume halting for this session (or globally).")
    sp_r.add_argument("--session-id", default=None)

    sp_ii = sub.add_parser(
        "install-indicator",
        help="Install cost-guard's bottom-row indicator. If a bottom-row command already exists you will be asked whether to compose or replace.",
    )
    sp_ii.add_argument(
        "mode",
        nargs="?",
        default=None,
        help="Optional: 'compose' (wrap existing command + append cost-guard row) or 'replace' (take over; existing is backed up).",
    )

    sub.add_parser("uninstall-indicator", help="Remove cost-guard's indicator; restore the previous bottom-row command if one existed.")

    return p


DISPATCH = {
    "status": cmd_status,
    "diag": cmd_diag,
    "set-session-limit": cmd_set_session_limit,
    "set-step-limit": cmd_set_step_limit,
    "set-rate": cmd_set_rate,
    "set-subagent-cap": cmd_set_subagent_cap,
    "set-warn": cmd_set_warn,
    "pause": cmd_pause,
    "resume": cmd_resume,
    "install-indicator": cmd_install_indicator,
    "uninstall-indicator": cmd_uninstall_indicator,
}


def main(argv: Optional[List[str]] = None) -> int:
    args = build_parser().parse_args(argv)
    if args.cmd == "halt-check":
        return cmd_halt_check()
    if args.cmd == "indicator":
        return cmd_indicator()
    handler = DISPATCH.get(args.cmd)
    if handler is None:
        build_parser().print_help()
        return 2
    return handler(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except SystemExit:
        raise
    except Exception as exc:
        try:
            _append_jsonl(HALT_LOG, {
                "ts": datetime.now(timezone.utc).isoformat(),
                "decision": "error",
                "reason": f"{type(exc).__name__}: {exc}",
                "argv": sys.argv,
            })
        except Exception:
            pass
        sys.exit(0)
